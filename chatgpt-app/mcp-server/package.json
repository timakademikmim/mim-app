{
  "name": "mim-chatgpt-exam-mcp",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Local MCP server scaffold for ChatGPT App exam draft tools",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/index.ts",
    "dev:http": "tsx src/http-server.ts",
    "smoke": "tsx src/smoke-test.ts",
    "smoke:http": "tsx src/http-smoke-test.ts",
    "start": "node --enable-source-maps ./dist/index.js",
    "start:http": "node --enable-source-maps ./dist/http-server.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "latest",
    "dotenv": "^16.4.7",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "tsx": "^4.20.3",
    "typescript": "^5.8.3"
  }
}
