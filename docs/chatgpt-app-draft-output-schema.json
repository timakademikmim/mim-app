{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "MIM Exam AI Draft Output",
  "type": "object",
  "required": [
    "instruksi",
    "instruksi_lang",
    "sections",
    "questions"
  ],
  "properties": {
    "instruksi": {
      "type": "string"
    },
    "instruksi_lang": {
      "type": "string",
      "enum": ["ID", "AR"]
    },
    "source": {
      "type": "string",
      "const": "chatgpt-app"
    },
    "sections": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["type", "start", "end", "count"],
        "properties": {
          "type": {
            "type": "string",
            "enum": ["pilihan-ganda", "benar-salah", "esai", "isi-titik"]
          },
          "start": {
            "type": "integer",
            "minimum": 1
          },
          "end": {
            "type": "integer",
            "minimum": 1
          },
          "count": {
            "type": "integer",
            "minimum": 1
          },
          "instruction": {
            "type": "string"
          },
          "score": {
            "type": ["number", "null"]
          }
        },
        "additionalProperties": false
      }
    },
    "questions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["no", "type", "text"],
        "properties": {
          "no": {
            "type": "integer",
            "minimum": 1
          },
          "type": {
            "type": "string",
            "enum": ["pilihan-ganda", "benar-salah", "esai", "isi-titik"]
          },
          "text": {
            "type": "string"
          },
          "answer": {
            "type": "string"
          },
          "options": {
            "type": "object",
            "properties": {
              "a": { "type": "string" },
              "b": { "type": "string" },
              "c": { "type": "string" },
              "d": { "type": "string" },
              "e": { "type": "string" }
            },
            "additionalProperties": false
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
