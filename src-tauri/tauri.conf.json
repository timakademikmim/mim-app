{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MIM App",
  "version": "0.3.50",
  "identifier": "com.mim.app",
  "build": {
    "beforeDevCommand": "node scripts/build-desktop-assets.mjs",
    "beforeBuildCommand": "node scripts/build-desktop-assets.mjs",
    "frontendDist": "../dist-tauri-web"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "MIM App",
        "width": 1400,
        "height": 900,
        "maximized": true,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "active": true,
      "dialog": false,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEJFMUMzODEzMkYwNDM1MzUKUldRMU5RUXZFemdjdnQrKy9OR2k5R1JOUGVrM3ZDQTNFSnBiMmdudnkyNXhzNDJRSXVsQkgzYUsK",
      "endpoints": [
        "https://github.com/timakademikmim/mim-app/releases/latest/download/latest.json"
      ]
    }
  }
}

